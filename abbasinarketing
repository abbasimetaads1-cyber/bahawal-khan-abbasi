            --card-bg: #161b22;
            --accent-blue: #00d2ff;
            --accent-gold: #ffcc00;
            --text-main: #ffffff;
            --text-dim: #a1a1a1;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-dark); color: var(--text-main); line-height: 1.6; }

        /* --- Header & Hero --- */
        header { padding: 2rem 5%; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.5rem; font-weight: 800; color: var(--accent-blue); text-transform: uppercase; }

        .hero { height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 0 10%; background: radial-gradient(circle at center, #1a2333 0%, var(--bg-dark) 70%); }
        .hero h1 { font-size: 3.5rem; margin-bottom: 1rem; letter-spacing: -1px; }
        .hero span { color: var(--accent-blue); }
        .hero p { font-size: 1.2rem; color: var(--text-dim); max-width: 700px; margin-bottom: 2rem; }

        /* --- Buttons --- */
        .cta-btn { background: linear-gradient(45deg, var(--accent-blue), #0072ff); color: white; padding: 1rem 2.5rem; border-radius: 50px; text-decoration: none; font-weight: bold; transition: 0.3s; box-shadow: 0 10px 20px rgba(0, 210, 255, 0.3); }
        .cta-btn:hover { transform: translateY(-3px); box-shadow: 0 15px 25px rgba(0, 210, 255, 0.5); }

        /* --- Results Gallery --- */
        .section-title { text-align: center; margin: 4rem 0 2rem; font-size: 2.5rem; }
        .results-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; padding: 0 5% 4rem; }
        .result-card { background: var(--card-bg); border-radius: 12px; overflow: hidden; border: 1px solid #30363d; transition: 0.3s; }
        .result-card:hover { border-color: var(--accent-blue); }
        .result-card img { width: 100%; height: auto; display: block; }
        .result-info { padding: 1.5rem; }
        .result-tag { color: var(--accent-blue); font-size: 0.8rem; font-weight: bold; text-transform: uppercase; }

        /* --- Services --- */
        .services { display: flex; gap: 20px; padding: 4rem 5%; justify-content: center; flex-wrap: wrap; }
        .service-card { background: var(--card-bg); padding: 2rem; border-radius: 15px; width: 45%; min-width: 300px; text-align: center; }
        .service-card i { font-size: 2.5rem; color: var(--accent-gold); margin-bottom: 1rem; }

        /* --- Contact --- */
        .contact-section { background: #111; padding: 4rem 5%; text-align: center; }
        .contact-info { margin-top: 2rem; display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; }
        .contact-item { font-size: 1.1rem; color: var(--text-main); text-decoration: none; }
        .contact-item i { color: var(--accent-blue); margin-right: 10px; }

        footer { text-align: center; padding: 2rem; border-top: 1px solid #222; color: var(--text-dim); font-size: 0.9rem; }
