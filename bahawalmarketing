        /* --- Header --- */
        header { padding: 1.5rem 0; border-bottom: 1px solid #161b22; }
        .nav-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.4rem; font-weight: 900; letter-spacing: 1px; color: var(--text-main); }
        .logo span { color: var(--accent-blue); }

        /* --- Hero --- */
        .hero { text-align: center; padding: 120px 0 80px; background: radial-gradient(circle at top, #111827 0%, var(--bg-dark) 60%); }
        .hero h1 { font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.1; margin-bottom: 1.5rem; }
        .hero p { color: var(--text-dim); font-size: 1.2rem; max-width: 650px; margin: 0 auto 2.5rem; }

        /* --- Results Grid --- */
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 25px; margin-top: 40px; }
        .card { background: var(--card-bg); border: 1px solid #30363d; border-radius: 16px; overflow: hidden; position: relative; }
        .card img { width: 100%; height: auto; transition: 0.5s; display: block; }
        .card:hover img { transform: scale(1.03); }
        .card-label { position: absolute; top: 15px; left: 15px; background: rgba(0,0,0,0.7); padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: bold; color: var(--accent-blue); backdrop-filter: blur(5px); }

        /* --- Testimonials --- */
        .testimonials { background: #0a0c10; border-top: 1px solid #161b22; }
        .testimonial-card { background: #161b22; padding: 2.5rem; border-radius: 20px; border-left: 4px solid var(--accent-blue); }
        .client-info { display: flex; align-items: center; margin-bottom: 1.5rem; }
        .client-meta h4 { margin-bottom: 2px; display: flex; align-items: center; gap: 8px; }
        .verified-badge { color: var(--verified-green); font-size: 0.9rem; }
        .client-niche { font-size: 0.85rem; color: var(--text-dim); }
        .testimonial-text { font-style: italic; color: #d1d5db; font-size: 1.05rem; line-height: 1.8; }

        /* --- Contact --- */
        .contact-box { background: linear-gradient(135deg, #111, #000); padding: 60px; border-radius: 30px; text-align: center; border: 1px solid #333; }
        .contact-links { display: flex; justify-content: center; gap: 30px; margin-top: 30px; flex-wrap: wrap; }
        .contact-links a { color: var(--text-main); text-decoration: none; font-size: 1.1rem; }
        .contact-links i { color: var(--accent-blue); margin-right: 8px; }

